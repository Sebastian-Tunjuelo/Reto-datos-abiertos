# API datos.gov.co (opcional — aumenta rate limit)
SOCRATA_APP_TOKEN=

# Base de datos PostgreSQL
POSTGRES_URL=postgresql://siembrasegura:siembrasegura@localhost:5432/siembrasegura

# LLM (Google Gemini — obtener key en https://aistudio.google.com/app/apikey)
# Para rotación automática de cuota, agrega varias keys separadas por coma:
# LLM_API_KEY=key1,key2,key3
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash

# LLM Fallback (Anthropic Claude — obtener key en https://console.anthropic.com/)
# Se usa automáticamente si todas las keys de Gemini agotan su cuota
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Rutas de datos
DATA_DIR=./data
MODELS_DIR=./models

# Logging
LOG_LEVEL=INFO
